# -----------------------------------------------------------------------------
# Firebase Web App configuration for local development.
#
# How to fill this in:
#   1. Go to https://console.firebase.google.com/
#   2. Open (or create) your project.
#   3. Project settings (gear icon, top left) -> General tab.
#   4. Scroll to "Your apps" and pick (or register) a Web app.
#   5. Under "SDK setup and configuration" copy each value from the `firebaseConfig`
#      object into the matching variable below.
#
# Copy this file to `.env` (same directory) and fill in the values. The `.env`
# file is listed in .gitignore and must never be committed.
#
# The `VITE_` prefix is required by Vite to expose a variable to client code.
# -----------------------------------------------------------------------------

# Web API key for the Firebase project (firebaseConfig.apiKey).
# Safe to expose in client code — Firestore access is still gated by security rules.
VITE_FIREBASE_API_KEY=

# Auth domain, typically `<project-id>.firebaseapp.com` (firebaseConfig.authDomain).
# This is also where the Google Sign-In popup is hosted.
VITE_FIREBASE_AUTH_DOMAIN=

# Firebase project ID (firebaseConfig.projectId).
# Must match the project whose Firestore database and Auth you want to use.
VITE_FIREBASE_PROJECT_ID=

# Default Cloud Storage bucket (firebaseConfig.storageBucket).
# Included for completeness; this app does not currently upload files.
VITE_FIREBASE_STORAGE_BUCKET=

# Cloud Messaging sender ID (firebaseConfig.messagingSenderId).
# Not used directly by this app but required by the Firebase SDK config shape.
VITE_FIREBASE_MESSAGING_SENDER_ID=

# App ID identifying this particular Web app within the project (firebaseConfig.appId).
VITE_FIREBASE_APP_ID=
